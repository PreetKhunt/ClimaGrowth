# ClimaGrowth – Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Google Gemini AI (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps (https://console.cloud.google.com → APIs → Maps SDK)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase project ID (from Firebase Console)
FIREBASE_PROJECT_ID=climagrowth-xxxxx

# Open-Meteo — no key required
# OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
